{
  "name": "@wareable/server",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node-pg-migrate up --migration-file-language sql --migrations-dir src/db/migrations --database-url-var DATABASE_URL",
    "db:migrate:down": "node-pg-migrate down --migration-file-language sql --migrations-dir src/db/migrations --database-url-var DATABASE_URL",
    "db:seed": "tsx src/db/seeds/run.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@wareable/shared": "workspace:*",
    "fastify": "^5.2.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "fastify-plugin": "^5.0.0",
    "pg": "^8.13.0",
    "ioredis": "^5.4.0",
    "google-auth-library": "^9.15.0",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/pg": "^8.11.0",
    "@types/node": "^22.0.0",
    "node-pg-migrate": "^7.9.0",
    "vitest": "^3.0.0"
  }
}
