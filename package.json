{
  "name": "wareable-toy",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev:web": "pnpm --filter @wareable/web dev",
    "dev:server": "pnpm --filter @wareable/server dev",
    "dev:all": "pnpm run --parallel dev:web dev:server",
    "build": "pnpm run --filter './apps/*' build",
    "db:migrate": "pnpm --filter @wareable/server db:migrate",
    "db:seed": "pnpm --filter @wareable/server db:seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "lint": "pnpm run --recursive lint",
    "typecheck": "pnpm run --recursive typecheck"
  }
}
